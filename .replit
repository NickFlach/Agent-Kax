modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
KANNAKA_OWNER_EMAIL = "nikolaiflaukowski@gmail.com"

[userenv.development]

[userenv.production]
KAX_CLAIM_FROM_USER_ID = "39143452"
KAX_CLAIM_TO_WALLET = "0x5c2fff175128addd8b982ecf87fb4f61150095aa"
